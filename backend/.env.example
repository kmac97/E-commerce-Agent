# ─────────────────────────────────────────
# E-commerce AI Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────

# CORS — comma-separated origins allowed to call the API.
# Leave unset to use the dashboard's default Vercel domains (see config.py).
# Add a local dev origin (e.g. http://127.0.0.1:5500) if you test the
# frontend locally.
ALLOWED_ORIGINS=

# API AUTH (dashboard sends this back as X-Api-Key)
# Generate with: openssl rand -hex 32
API_KEY=

# AI MODEL
# Reached via OpenRouter (not the Anthropic API directly) -- one key covers
# every model OpenRouter hosts, including Claude.
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Extraction/classification tier. Same default as above for now; split onto a
# different model later (e.g. anthropic/claude-sonnet-5 on OPENROUTER_MODEL)
# without touching the extraction call sites.
OPENROUTER_FAST_MODEL=anthropic/claude-haiku-4.5
# Fallback if the primary model/provider is down (tools/llm_client.py) --
# deliberately non-Anthropic for real redundancy.
OPENROUTER_FALLBACK_MODEL=openai/gpt-5.6-luna
# Research synthesis only (agents/researcher.py) -- heavier/pricier than the
# default above, deliberately scoped to just this one low-frequency task.
OPENROUTER_RESEARCH_MODEL=anthropic/claude-sonnet-5

# TELEGRAM
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-personal-chat-id

# SUPABASE
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# WEB SEARCH
SERPER_API_KEY=your-serper-api-key

# SHOPIFY (fill in when store is ready)
# Create a custom app in Shopify admin (Settings > Apps > Develop apps) and
# use its Admin API access token here -- no OAuth flow needed for a
# single self-owned store.
SHOPIFY_SHOP_URL=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=
# The custom app's "API secret key" (shown next to the access token) --
# used to verify Shopify webhook deliveries in api/webhooks.py.
SHOPIFY_WEBHOOK_SECRET=

# META ADS (Phase 4)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# TIKTOK ADS (Phase 4)
TIKTOK_APP_ID=
TIKTOK_SECRET=
TIKTOK_ACCESS_TOKEN=

# GMAIL (Phase 5)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
