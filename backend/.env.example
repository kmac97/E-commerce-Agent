# ─────────────────────────────────────────
# E-commerce AI Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────

# CORS — comma-separated origins allowed to call the API.
# Leave unset to use the dashboard's default Vercel domains (see config.py).
# Add a local dev origin (e.g. http://127.0.0.1:5500) if you test the
# frontend locally.
ALLOWED_ORIGINS=

# API AUTH (dashboard sends this back as X-Api-Key)
# Generate with: openssl rand -hex 32
API_KEY=

# AI MODEL
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-70b

# TELEGRAM
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-personal-chat-id

# SUPABASE
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# WEB SEARCH
SERPER_API_KEY=your-serper-api-key

# SHOPIFY (fill in when store is ready)
SHOPIFY_SHOP_URL=yourstore.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=

# META ADS (Phase 4)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# TIKTOK ADS (Phase 4)
TIKTOK_APP_ID=
TIKTOK_SECRET=
TIKTOK_ACCESS_TOKEN=

# GMAIL (Phase 5)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
